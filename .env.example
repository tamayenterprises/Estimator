# Copy to .env for local runs. Never commit real keys.
STRIPE_SECRET_KEY=sk_test_your_secret_here
STRIPE_PUBLIC_KEY=pk_test_your_publishable_here
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Google Calendar (optional — leave unset to keep scheduler demo slots only)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/oauth/google/callback
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_CALENDAR_ID=primary
# BOOKING_TIMEZONE=America/New_York
# BOOKING_SLOT_DURATION_MINUTES=90
